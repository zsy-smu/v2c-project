# =============================================================
# V2C Project — 环境变量配置模板
# 使用方法：将本文件复制为 .env，然后填写各项的实际值
#   cp .env.example .env
#   nano .env
# 注意：.env 文件包含敏感信息，已加入 .gitignore，不会上传到 GitHub
#
# 重要说明：所有 key 均使用标准 ASCII 命名，以兼容 systemd EnvironmentFile
# 和 Node.js dotenv 等工具（systemd 仅支持 [A-Za-z0-9_] 格式的 key）
# =============================================================

# -------------------------------------------------------
# 【服务器基础配置】
# -------------------------------------------------------

# 后端服务监听的端口号
# 默认 3000，局域网访问地址为 http://设备IP:3000
PORT=3000

# 运行环境：development（开发调试）或 production（生产部署）
# Jetson / 树莓派实体部署时填写 production
NODE_ENV=production

# -------------------------------------------------------
# 【数据库配置】（如果项目使用数据库，取消注释并填写）
# -------------------------------------------------------

# 数据库连接地址（本地部署填 localhost，远程数据库填服务器 IP）
# DB_HOST=localhost

# 数据库端口（MySQL 默认 3306，PostgreSQL 默认 5432）
# DB_PORT=3306

# 数据库名称
# DB_NAME=v2c_db

# 数据库用户名
# DB_USER=v2c_user

# 数据库密码（务必修改为强密码）
# DB_PASSWORD=请填写你的数据库密码

# -------------------------------------------------------
# 【Redis 缓存配置】（如果项目使用 Redis，取消注释并填写）
# -------------------------------------------------------

# Redis 服务地址
# REDIS_HOST=127.0.0.1

# Redis 端口（默认 6379）
# REDIS_PORT=6379

# Redis 访问密码（没有密码则留空）
# REDIS_PASSWORD=

# -------------------------------------------------------
# 【视觉与控制接口配置】
# -------------------------------------------------------

# 视觉推理设备（Jetson）的局域网 IP 地址（运行 YOLO 推理的设备）
JETSON_DEVICE_IP=192.168.1.50

# Jetson 数据推送端口（视觉端推送目标坐标使用的端口）
JETSON_DATA_PORT=9000

# 控制端（MuJoCo / G1 机器人）的接收地址
CONTROLLER_IP=192.168.1.60

# 控制端数据接收端口
CONTROLLER_PORT=8888

# -------------------------------------------------------
# 【GPIO 按键功能配置】（需要连接物理按键时开启）
# 树莓派使用 RPi.GPIO，Jetson 使用 Jetson.GPIO（API 兼容）
# -------------------------------------------------------

# 是否启用 GPIO 按键触发功能：true 开启，false 关闭
# 开启前请确认已按照 gpio_demo/ 目录说明完成接线
GPIO_ENABLE=false

# GPIO 按钮连接的引脚编号（使用 BCM 编号方式）
# 默认使用 GPIO 17 引脚（物理引脚 11）
GPIO_BUTTON_PIN=17

# 按钮触发时调用的后端接口路径
# 例如：/api/trigger 表示 POST http://localhost:3000/api/trigger
GPIO_TRIGGER_PATH=/api/trigger

# -------------------------------------------------------
# 【日志与调试配置】
# -------------------------------------------------------

# 日志级别：error（只记录错误）、warn（警告）、info（信息）、debug（调试详情）
# 生产环境建议使用 info，调试时改为 debug
LOG_LEVEL=info

# 是否将日志写入文件：true 写入，false 仅输出到终端/systemd 日志
LOG_TO_FILE=false

# 日志文件存放路径（启用写入日志文件时有效）
# Jetson 部署时路径示例：/home/nvidia/v2c-project/logs/app.log
LOG_FILE_PATH=/home/nvidia/v2c-project/logs/app.log
