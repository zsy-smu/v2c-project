# =============================================================
# V2C Project — 环境变量配置模板 / Environment Variables Template
# 使用方法：将本文件复制为 .env，然后填写各项的实际值
#   cp .env.example .env
#   nano .env
# 注意：.env 文件包含敏感信息，已加入 .gitignore，不会上传到 GitHub
# Note: .env contains sensitive data and is excluded from git.
# =============================================================

# ── Server / 服务器基础配置 ───────────────────────────────────────────────────
# 后端服务监听的端口号 (default 3000; LAN access: http://pi-ip:3000)
PORT=3000

# Absolute or relative path to the SQLite database file / SQLite 数据库文件路径
DB_PATH=./reports.db

# ── Python / Report Fetcher / 位置数据抓取配置 ──────────────────────────────
# Python executable — use venv path if you created one, e.g. ./venv/bin/python3
# Python 可执行路径，使用 venv 时改为 ./venv/bin/python3
PYTHON_CMD=python3

# Cron schedule for automatic location data fetching (default: every 5 min)
# 自动拉取位置数据的 Cron 表达式（默认每 5 分钟一次）
REPORT_CRON=*/5 * * * *

# ── Anisette Server / Anisette Docker 服务 ────────────────────────────────────
# URL of the Anisette v3 Docker container / Anisette v3 容器地址
ANISETTE_SERVER=http://localhost:6969

# ── V2C — Vision & Control Endpoints / 视觉与控制接口配置 ────────────────────
# Jetson device LAN IP (running YOLO inference) / Jetson 设备的局域网 IP
JETSON_HOST=192.168.1.50

# Jetson data push port / Jetson 数据推送端口
JETSON_PORT=9000

# Control endpoint (MuJoCo / G1 robot) / 控制端（MuJoCo / G1 机器人）地址
CONTROL_HOST=192.168.1.60

# Control endpoint receive port / 控制端数据接收端口
CONTROL_PORT=8888

# ── GPIO (optional physical button trigger) / GPIO 按键功能配置 ─────────────
# Set to "true" to enable the GPIO button scaffold on Raspberry Pi
# 是否启用 GPIO 按键触发功能：true 开启，false 关闭
ENABLE_GPIO=false

# BCM GPIO pin number connected to the physical button (default 18)
# GPIO 按钮连接的引脚编号（BCM 编号，默认 18）
GPIO_BUTTON_PIN=18

# API endpoint to call when button is pressed (must be reachable from Pi)
# 按钮触发时调用的后端接口 URL
GPIO_TRIGGER_URL=http://localhost:3000/health

# Software debounce time in milliseconds (prevents false triggers) / 软件去抖动时间（毫秒）
GPIO_DEBOUNCE_MS=300

# ── Logging / 日志配置 ────────────────────────────────────────────────────────
# Log level: error | warn | info | debug
# 日志级别
LOG_LEVEL=info
