# ── Server ───────────────────────────────────────────────────────────────────
# Port for the Express query API
PORT=3000

# Absolute or relative path to the SQLite database file
DB_PATH=./reports.db

# ── Python / Report Fetcher ───────────────────────────────────────────────────
# Python executable — use venv path if you created one, e.g. ./venv/bin/python3
PYTHON_CMD=python3

# Cron schedule for automatic location data fetching (default: every 5 min)
REPORT_CRON=*/5 * * * *

# ── Anisette Server ───────────────────────────────────────────────────────────
# URL of the Anisette v3 Docker container
ANISETTE_SERVER=http://localhost:6969

# ── GPIO (optional physical button trigger) ───────────────────────────────────
# Set to "true" to enable the GPIO button scaffold on Raspberry Pi
ENABLE_GPIO=false

# BCM GPIO pin number connected to the physical button
GPIO_BUTTON_PIN=18

# API endpoint to call when button is pressed (must be reachable from Pi)
GPIO_TRIGGER_URL=http://localhost:3000/health

# Software debounce time in milliseconds (prevents false triggers)
GPIO_DEBOUNCE_MS=300
