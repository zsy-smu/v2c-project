# ============================================================
# V2C Project — 环境变量配置模板
# 使用说明：
#   1. 将本文件复制为 .env：
#      cp .env.example .env
#   2. 根据实际情况修改下方各项配置
#   3. .env 文件包含敏感信息，不要提交到 Git 仓库！
#      （已在 .gitignore 中排除）
# ============================================================


# ============================================================
# 【基础服务配置】
# ============================================================

# 运行环境
#   development — 开发模式（详细日志、热重载等）
#   production  — 生产模式（性能优化、精简日志）
NODE_ENV=production

# 服务监听端口（默认 3000，局域网访问时需确保防火墙放行此端口）
PORT=3000

# 服务绑定地址
#   0.0.0.0 — 允许局域网内所有 IP 访问（树莓派部署推荐）
#   127.0.0.1 — 仅本机访问
HOST=0.0.0.0


# ============================================================
# 【数据库配置】（根据实际使用的数据库填写）
# ============================================================

# 数据库类型（mysql / postgresql / sqlite / mongodb）
DB_TYPE=sqlite

# 数据库连接地址（SQLite 使用本地文件路径；其他数据库填 IP 或域名）
DB_HOST=localhost

# 数据库端口（MySQL 默认 3306，PostgreSQL 默认 5432）
DB_PORT=3306

# 数据库名称
DB_NAME=v2c_db

# 数据库用户名
DB_USER=v2c_user

# 数据库密码（请修改为强密码！）
DB_PASSWORD=请修改为你的数据库密码


# ============================================================
# 【安全配置】
# ============================================================

# JWT 密钥（用于用户登录 Token 签名，请使用随机字符串，越长越安全）
# 生成示例：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=请修改为随机的强密钥字符串

# JWT 有效期（例如：1d=1天，7d=7天，1h=1小时）
JWT_EXPIRES_IN=7d

# CORS 允许的来源域名（多个用逗号分隔，* 表示允许所有来源）
# 生产环境请填写实际前端域名或 IP，不要使用 *
CORS_ORIGIN=*


# ============================================================
# 【视觉服务配置（V2C 核心）】
# ============================================================

# 视觉推理服务地址（运行 YOLO 的 Jetson Orin Nano 或本机 IP）
VISION_SERVICE_HOST=127.0.0.1

# 视觉推理服务端口
VISION_SERVICE_PORT=8080

# 视觉推理超时时间（毫秒）
VISION_TIMEOUT_MS=5000

# 是否启用视觉服务（true/false，调试时可关闭）
VISION_ENABLED=true


# ============================================================
# 【控制服务配置（MuJoCo / ROS / 机器人通信）】
# ============================================================

# 控制服务通信协议（socket / ros / http）
CONTROL_PROTOCOL=socket

# 控制服务主机地址
CONTROL_HOST=127.0.0.1

# 控制服务端口
CONTROL_PORT=9090

# 控制指令发送超时时间（毫秒）
CONTROL_TIMEOUT_MS=3000


# ============================================================
# 【日志配置】
# ============================================================

# 日志级别（error / warn / info / debug，生产环境推荐 info）
LOG_LEVEL=info

# 日志文件存放目录（留空则只输出到控制台）
LOG_DIR=./logs

# 单个日志文件最大大小（超过则自动轮转，例如：10m / 50m）
LOG_MAX_SIZE=10m

# 保留最近几天的日志文件
LOG_MAX_DAYS=7


# ============================================================
# 【GPIO 配置（树莓派物理按键，可选）】
# ============================================================

# 是否启用 GPIO 监听（仅树莓派环境有效，其他平台请设为 false）
GPIO_ENABLED=false

# GPIO 按键对应的 BCM 引脚编号（参考 docs/raspberry-pi-deploy.md）
GPIO_BUTTON_PIN=17

# 按键防抖延迟（毫秒，避免一次按键触发多次）
GPIO_DEBOUNCE_MS=200
