# =============================================================
# V2C Project — 环境变量配置模板
# 使用方法：将本文件复制为 .env，然后填写各项的实际值
#   cp .env.example .env
#   nano .env
# 注意：.env 文件包含敏感信息，已加入 .gitignore，不会上传到 GitHub
# 适用平台：Jetson Orin Nano Super 8G + JetPack 6.1（默认用户：nvidia）
# =============================================================

# -------------------------------------------------------
# 【服务器基础配置】
# -------------------------------------------------------

# 后端服务监听的端口号
# 默认 3000，局域网访问地址为 http://JetsonIP:3000
服务端口=3000

# 运行环境：development（开发调试）或 production（生产部署）
# Jetson 实体部署时填写 production
运行环境=production

# -------------------------------------------------------
# 【数据库配置】（如果项目使用数据库，取消注释并填写）
# -------------------------------------------------------

# 数据库连接地址（本地部署填 localhost，远程数据库填服务器 IP）
# 数据库地址=localhost

# 数据库端口（MySQL 默认 3306，PostgreSQL 默认 5432）
# 数据库端口=3306

# 数据库名称
# 数据库名=v2c_db

# 数据库用户名
# 数据库用户名=v2c_user

# 数据库密码（务必修改为强密码）
# 数据库密码=请填写你的数据库密码

# -------------------------------------------------------
# 【Redis 缓存配置】（如果项目使用 Redis，取消注释并填写）
# -------------------------------------------------------

# Redis 服务地址
# Redis地址=127.0.0.1

# Redis 端口（默认 6379）
# Redis端口=6379

# Redis 访问密码（没有密码则留空）
# Redis密码=

# -------------------------------------------------------
# 【视觉与控制接口配置】
# -------------------------------------------------------

# Jetson 视觉推理端的局域网 IP 地址（运行 YOLO 推理的设备）
# 如果视觉和后端在同一台 Jetson，填写 127.0.0.1
# 如果分别在不同 Jetson，填写视觉 Jetson 的局域网 IP
Jetson设备地址=127.0.0.1

# Jetson 数据推送端口（视觉端推送目标坐标使用的端口）
Jetson数据端口=9000

# 控制端（MuJoCo / G1 机器人）的接收地址
控制端地址=192.168.1.60

# 控制端数据接收端口
控制端口=8888

# -------------------------------------------------------
# 【GPIO 按键功能配置】（Jetson 实体部署时可用）
# 注意：Jetson 使用 Jetson.GPIO 库，非 RPi.GPIO
# 引脚编号参考 Jetson Orin Nano 的引脚图
# -------------------------------------------------------

# 是否启用 GPIO 按键触发功能：true 开启，false 关闭
# 开启前请确认已按照 gpio_demo/ 目录说明完成接线
# 并已安装 Jetson.GPIO 库：pip3 install Jetson.GPIO
启用GPIO按键=false

# GPIO 按钮连接的引脚编号（使用 BCM 编号方式）
# 参考 Jetson Orin Nano 的引脚图，默认使用 GPIO 17
GPIO按钮引脚=17

# 按钮触发时调用的后端接口路径
# 例如：/api/trigger 表示 POST http://localhost:3000/api/trigger
GPIO触发接口路径=/api/trigger

# -------------------------------------------------------
# 【日志与调试配置】
# -------------------------------------------------------

# 日志级别：error（只记录错误）、warn（警告）、info（信息）、debug（调试详情）
# 生产环境建议使用 info，调试时改为 debug
日志级别=info

# 是否将日志写入文件：true 写入，false 仅输出到终端/systemd 日志
写入日志文件=false

# 日志文件存放路径（启用写入日志文件时有效）
# Jetson 默认用户目录为 /home/nvidia，setup_jetson.sh 会自动替换此路径
日志文件路径=/home/nvidia/v2c-project/logs/app.log
