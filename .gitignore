# =============================================================
# V2C Project — .gitignore
# 以下文件/目录不会上传到 GitHub，保护敏感信息
# =============================================================

# Environment secrets / 环境变量（含敏感配置）
.env

# Dependencies / Node.js 依赖
node_modules/

# Python virtual environment / Python 虚拟环境
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# Runtime data / 运行时数据
reports.db
*.db-shm
*.db-wal

# Key files — NEVER commit private keys / 私钥文件（绝对不能提交）
keys/*.key
keys/*.json

# Logs / 日志
logs/
*.log
npm-debug.log*

# macOS
.DS_Store
Thumbs.db

# Editor / 编辑器配置
.vscode/
.idea/
*.swp
*.swo
