# 环境变量文件（包含敏感配置，不上传）
.env

# 日志目录
logs/

# Node.js 依赖目录
node_modules/

# Python 虚拟环境
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# 操作系统生成的文件
.DS_Store
Thumbs.db

# 编辑器配置文件
.vscode/
.idea/
*.swp
*.swo

# EmbodiedBench run artifacts (keep the directory placeholder)
artifacts/run_*.jsonl

# Python packaging build artifacts
*.egg-info/
dist/
build/
